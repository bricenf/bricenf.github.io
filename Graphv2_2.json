{
  "$schema": "https://vega.github.io/schema/vega/v5.json","width": 900,"height": 560,"padding": {"top": 0, "left": 0, "right": 0, "bottom": 0},"autosize": "none",

  "signals":[
    "name":"indicators",
    "value":"Population Density",
    "bind": {
      "input":"select",
      "options":[
        "Population Density",
        "Population, Male",
        "Population, Female"
      ]
    }
  ],


  "data": [
    {
      "name": "states",
      "url": "data/us-10m.json",
      "format": {"type": "topojson", "feature": "states"},
      "transform": [
        {
          "type": "geopath",
          "projection": "projection"
        }
      ]
    },
    {
      "name": "areas",
      "url": "data/areas.csv",
      "format": {"type": "csv", "parse": "auto"},
      "transform": [
        {
          "type": "geopoint",
          "projection": "projection",
          "fields": ["longitude", "latitude"]
        },
        {
          "type": "filter",
          "expr": "datum.x != null && datum.y != null"
        }
      ]
    }
  ],

  "projections": [
    {
      "name": "indicators",
      "type": {"signal":"indicators"},
      "scale": 1000,
      "translate": [{"signal": "width / 2"}, {"signal": "height / 2"}]
    }
  ],

  "marks": [
    {
      "type": "path",
      "from": {"data": "states"},
      "encode": {
        "enter": {
          "fill": {"value": "#dedede"},
          "stroke": {"value": "white"}
        },
        "update": {
          "path": {"field": "path"}
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "areas"},
      "encode": {
        "enter": {
          "size": {"value": 2000},
          "fill": {"value": "steelblue"},
          "fillOpacity": {"value": 0.8},
          "stroke": {"value": "white"},
          "strokeWidth": {"value": 1.5}
        },
        "update": {
          "x": {"field": "x"},
          "y": {"field": "y"}
        }
      }

    }
  ]
}
